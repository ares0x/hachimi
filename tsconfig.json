{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "dist",
        "rootDir": ".",
        "baseUrl": ".",
        "paths": {
            "@hachimi/core": ["packages/core/src"],
            "@hachimi/core/*": ["packages/core/src/*"],
            "@hachimi/shared": ["packages/shared/src"],
            "@hachimi/shared/*": ["packages/shared/src/*"],
        },
    },
    "include": ["packages/**/*", "apps/**/*"],
    "exclude": ["node_modules", "dist", "**/dist"],
}
