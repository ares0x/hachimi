{
    "llm": {
        "provider": "deepseek",
        "deepseekModel": "deepseek-chat"
    },
    "paths": {
        "dataDir": "data"
    },
    "agent": {
        "maxToolRounds": 5
    },
    "context": {
        "maxTokens": 12000,
        "summaryThreshold": 25,
        "defaultMode": "normal",
        "enableTokenTruncation": true
    },
    "tui": {
        "title": "hachimi"
    }
}
